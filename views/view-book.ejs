<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Store</title>

    <style>

        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body{
            background: #f5f5f5;
            padding: 30px;
        }

        .container{
            width: 95%;
            margin: auto;
        }

        .top-bar{
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .top-bar h1{
            color: #222;
        }

        .add-btn{
            text-decoration: none;
            background: #222;
            color: white;
            padding: 12px 20px;
            border-radius: 8px;
            font-weight: bold;
            transition: 0.3s;
        }

        .add-btn:hover{
            background: #444;
        }

        table{
            width: 100%;
            border-collapse: collapse;
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        table th{
            background: #222;
            color: white;
            padding: 15px;
        }

        table td{
            padding: 15px;
            text-align: center;
            border-bottom: 1px solid #ddd;
        }

        table tr:hover{
            background: #f9f9f9;
        }

        img{
            border-radius: 8px;
            object-fit: cover;
        }

        .btn{
            padding: 8px 15px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: bold;
            color: white;
            display: inline-block;
        }

        .edit{
            background: #ffb300;
            color: black;
        }

        .delete{
            background: crimson;
        }

        .summary{
            background: white;
            padding: 18px;
            border-radius: 10px;
            margin-bottom: 20px;
            box-shadow: 0 0 10px rgba(0,0,0,0.08);
        }

        .description {
            max-width: 300px;
            overflow-wrap: break-word;
            white-space: normal;
        }

    </style>

</head>
<body>

    <div class="container">

        <div class="top-bar">
            <h1>📚 Book Store Management</h1>

            <a href="/addBook" class="add-btn">
                Add Book
            </a>
        </div>

        <div class="summary">
            <h2>Total Books : <%= book.length %></h2>
        </div>

        <table>

            <tr>
                <th>Image</th>
                <th>Title</th>
                <th>Author</th>
                <th>Category</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Description</th>
                <th>Action</th>
            </tr>

            <% book.map((b)=>{ %>

                <tr>

                    <td>
                        <img src="<%= b.coverImage %>" width="80" height="80">
                    </td>

                    <td><%= b.bookTitle %></td>

                    <td><%= b.bookAuthor %></td>

                    <td><%= b.bookCategory %></td>

                    <td>₹ <%= b.bookPrice %></td>

                    <td><%= b.bookQty %></td>

                    <td class="description"><%= b.description %></td>

                    <td>
                        <a href="/editBook/<%= b._id %>" class="btn edit">
                            Edit
                        </a>

                        <a href="/deleteBook/<%= b._id %>"
                             onclick="return confirm('Are you sure you want to delete this book?')"
                            class="btn delete">
                            Delete
                        </a>
                    </td>

                </tr>

            <% }) %>

        </table>

    </div>

</body>
</html>
