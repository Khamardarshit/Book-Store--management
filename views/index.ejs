<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Store</title>

    <style>

        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body{
            background: #f5f5f5;
            padding: 40px;
        }

        h1{
            text-align: center;
            margin-bottom: 40px;
            font-weight: 500;
        }

        .book-container{
            width: 90%;
            margin: auto;
            display: flex;
            flex-wrap: wrap;
            gap: 30px;
            justify-content: center;
        }

        .card{
            width: 270px;
            background: white;
            border-radius: 10px;
            overflow: hidden;
            border: 1px solid #ccc;
            transition: 0.3s;
        }

        .card:hover{
            transform: translateY(-5px);
            box-shadow: 0 0 10px rgba(0,0,0,0.15);
        }

        .card img{
            width: 100%;
            height: 380px;
            object-fit: cover;
        }

        .card-body{
            padding: 18px;
        }

        .card-body h2{
            margin-bottom: 10px;
            font-size: 20px;
        }

        .card-body p{
            color: #333;
            line-height: 28px;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .btn{
            display: inline-block;
            margin-top: 18px;
            text-decoration: none;
            background: #222;
            color: white;
            padding: 10px 16px;
            border-radius: 6px;
            transition: 0.3s;
        }

        .btn:hover{
            background: #444;
        }

        .top-bar{
            width: 90%;
            margin: auto;
            margin-bottom: 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
         }

        .add-btn{
            text-decoration: none;
            background: #222;
            color: white;
            padding: 12px 18px;
            border-radius: 6px;
        }

        .add-btn:hover{
            background: #444;
        }

    </style>

</head>
<body>

    <div class="top-bar">

    <h1>Books Are Available In Book Store.</h1>

    <a href="/addBook" class="add-btn">
        Add Book
    </a>

</div>

    <div class="book-container">

        <% book.map((b)=>{ %>

            <div class="card">

                <img src="<%= b.coverImage %>">

                <div class="card-body">

                    <h2><%= b.bookTitle %></h2>

                    <p><%= b.description %></p>

                    <a href="/viewDetails/<%= b._id %>" class="btn">
                        View Book Details
                    </a>

                </div>

            </div>

        <% }) %>

    </div>

</body>
</html>