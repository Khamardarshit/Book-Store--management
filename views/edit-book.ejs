<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EDIT BOOK PAGE</title>

    <style>

        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body{
            background: #f5f5f5;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .form-container{
            width: 650px;
            background: white;
            padding: 35px;
            border-radius: 12px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        h1{
            text-align: center;
            margin-bottom: 25px;
            color: #222;
        }

        .input-group{
            margin-bottom: 18px;
        }

        label{
            display: block;
            margin-bottom: 8px;
            font-weight: bold;
            color: #333;
        }

        input{
            width: 100%;
            padding: 12px;
            border: 1px solid #ccc;
            border-radius: 8px;
            outline: none;
            transition: 0.3s;
        }   

        input:focus{
            border-color: #222;
        }

        img{
            display: block;
            margin: auto;
            margin-bottom: 20px;
            border-radius: 10px;
            object-fit: cover;
        }

        button{
            width: 100%;
            padding: 12px;
            border: none;
            background: #ffb300;
            color: black;
            font-size: 16px;
            font-weight: bold;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover{
            background: #e6a200;
        }

        .back-btn{
            display: inline-block;
            margin-top: 15px;
            text-decoration: none;
            color: #222;
            font-weight: bold;
        }
        select{ width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 8px; outline: none; background: white; font-size: 15px; transition: 0.3s; cursor: pointer; } select:focus{ border-color: #222; }

    </style>

</head>
<body>

    <div class="form-container">

        <h1>✏️ Edit Book</h1>

        <img src="<%= singleBook.coverImage %>" width="100" height="100">

        <form action="/updateBook/<%= singleBook._id %>" method="post" enctype="multipart/form-data">

            <div class="input-group">
                <label>Book Title</label>
                <input type="text" name="bookTitle" value="<%= singleBook.bookTitle %>" required>
            </div>

            <div class="input-group">
                <label>Author Name</label>
                <input type="text" name="bookAuthor" value="<%= singleBook.bookAuthor %>" required>
            </div>

            <div class="input-group">
    <label>Category</label>

    <select name="bookCategory" required>

        <option value="History"
        <%= singleBook.bookCategory === 'History' ? 'selected' : '' %>>
            History
        </option>

        <option value="Novel"
        <%= singleBook.bookCategory === 'Novel' ? 'selected' : '' %>>
            Novel
        </option>

        <option value="Biography"
        <%= singleBook.bookCategory === 'Biography' ? 'selected' : '' %>>
            Biography
        </option>

        <option value="Fiction"
        <%= singleBook.bookCategory === 'Fiction' ? 'selected' : '' %>>
            Fiction
        </option>

        <option value="Classic"
        <%= singleBook.bookCategory === 'Classic' ? 'selected' : '' %>>
            Classic
        </option>

        <option value="Nature"
        <%= singleBook.bookCategory === 'Nature' ? 'selected' : '' %>>
            Nature
        </option>

    </select>
</div>

            <div class="input-group">
                <label>Price</label>
                <input type="number" name="bookPrice" value="<%= singleBook.bookPrice %>" required>
            </div>

            <div class="input-group">
                <label>Quantity</label>
                <input type="number" name="bookQty" value="<%= singleBook.bookQty %>" required>
            </div>

            <div class="input-group">
                <label>Description</label>
                <input type="text" name="description" value="<%= singleBook.description %>" required>
            </div>

            <div class="input-group">
                <label>Change Cover Image</label>
                <input type="file" name="coverImage">
            </div>

            <button type="submit">Update Book</button>

        </form>

        <a href="/" class="back-btn"> <span style="font-weight: 800;"><</span> Back To Home</a>

    </div>

</body>
</html>
